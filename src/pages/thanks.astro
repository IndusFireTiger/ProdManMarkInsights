---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Thanks — ProdMan·Insights"
  description="Your message has been sent."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Message sent</p>
      <h1 style="max-width:16ch;">Thank you — your note is on its way.</h1>
      <p class="lede muted" style="max-width:48ch;">
        I'll get back to you at the email you provided. In the meantime, you're
        welcome to keep reading.
      </p>
      <div class="hero__cta" style="margin-top:2rem;">
        <a class="btn btn--accent" href="/perspectives">Read the perspectives</a>
        <a class="btn" href="/">Back home</a>
      </div>
    </div>
  </section>
</BaseLayout>
