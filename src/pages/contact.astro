---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact — ProdMan·Insights"
  description="Get in touch about product strategy, product marketing or AI in education."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Get in touch</p>
      <h1 style="max-width:16ch;">Let's compare notes.</h1>
      <p class="lede muted" style="max-width:50ch;">
        Product strategy, product marketing, applied AI, or AI in education —
        if any of it is on your mind, send a note. I read everything.
      </p>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/thanks"
        class="form"
        style="margin-top:2.5rem;"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hp">
          <label>Don't fill this out if you're human: <input name="bot-field" /></label>
        </p>

        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>

        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" required></textarea>
        </div>

        <button type="submit" class="btn btn--accent">Send message</button>
      </form>

      <p class="muted" style="margin-top:2rem; font-size:0.9rem;">
        Prefer email? <a href="mailto:prodmaninsights@gmail.com">prodmaninsights@gmail.com</a>
      </p>
    </div>
  </section>
</BaseLayout>
