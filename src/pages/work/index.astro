---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const work = (await getCollection('work'))
  .filter((w) => !w.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Work — ProdMan·Insights"
  description="Selected product case studies across enterprise data governance and EdTech."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Case studies</p>
      <h1 style="max-width:18ch;">Selected work</h1>
      <p class="lede muted" style="max-width:56ch;">
        A mix of enterprise product work and independent learning-lab projects —
        chosen to show range across discovery, MVP design, go-to-market and
        applied AI.
      </p>
      <div class="card-grid" style="margin-top:3rem;">
        {work.map((w) => (
          <a class="card" href={`/work/${w.id}`}>
            <span class="tag">{w.data.kind} · {w.data.focus.split('•')[0].trim()}</span>
            <h3>{w.data.title}</h3>
            <p>{w.data.summary}</p>
            <span class="more">View case study →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
